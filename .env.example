# ==============================================================
# Arquivo de configuração de exemplo
# Copie este arquivo para ".env" e preencha com seus dados reais
# NUNCA compartilhe o arquivo .env — ele contém suas credenciais
# ==============================================================

# --- SISTEMA DO LABORATÓRIO ---
# URL completa da tela de login do sistema
LAB_URL=https://SEU_SISTEMA_AQUI.com/login

# --- INTERVALO DE DATA PADRÃO ---
# Quantidade de dias retroativos para analisar quando rodar sem parâmetros
DIAS_ATRAS=7

# --- PASTA DE DESTINO DOS LAUDOS ---

# Onde os PDFs serão salvos localmente
PASTA_LAUDOS=C:/Laudos/

# --- CRITÉRIOS DE QUALIFICAÇÃO ---
# Texto exato da coluna Status (td[7]) que indica pedido pronto para processar
TEXTO_STATUS_FINALIZADO=FINALIZADO

# Classe CSS do ícone <i> na coluna Faturado (td[9]) que indica pago (✔ verde)
# Para descobrir: F12 → Console → cole:
#   document.querySelector('#tabela_pedido tbody tr td:nth-child(9) i').className
# Resultado esperado: algo como "fa fa-check text-success" → use "fa-check"
CLASSE_FATURADO_SIM=fa-check

# --- TIPO DE AMOSTRA ---
# O script só processa pedidos onde TODAS as amostras são deste tipo
# Conforme coluna "Tipo" da tabela de amostras do pedido
TIPO_AMOSTRA_PERMITIDO=Solo

# Cabeçalho da coluna de tipo na tabela de amostras
HEADER_COLUNA_TIPO_AMOSTRA=Tipo

# Seletor CSS da tabela de amostras dentro do pedido (inspecione e ajuste)
# Exemplo: table.tabela-amostras  ou  #tabela-amostras  ou  table (primeira tabela)
SELETOR_TABELA_AMOSTRAS=table

# --- XPATH DE NAVEGAÇÃO ---
# Os valores abaixo já estão preenchidos com os XPaths identificados no sistema.
# Só altere se o sistema mudar.

# Menu Comercial (navbar)
XPATH_MENU_COMERCIAL=//body/section[@class='ftco-section pt-3 print-none']/nav[@id='ftco-navbar']/div[@class='container-fluid']/div[@id='ftco-nav']/ul[@class='navbar-nav m-auto']/li[4]/a[1]

# Sub-menu Pedidos
XPATH_SUBMENU_PEDIDOS=//a[normalize-space()='Pedidos']

# Filtros de data na tela de Pedidos
XPATH_FILTRO_DATA_INICIO=//input[@id='dataInicialFiltro']
XPATH_FILTRO_DATA_FIM=//input[@id='dataFinalFiltro']

# Botão Filtrar (usado tanto em Pedidos quanto em Resultados)
XPATH_BTN_FILTRAR=//button[@type='submit']

# Tela de detalhe do Pedido — campos <input> (valor lido via atributo 'value')
# Telefone do solicitante/cliente
XPATH_TELEFONE_CLIENTE=//body/section/div[@class='col page']/main[@id='mainRelatorio']/div[@class='container-box-shadow pt-1 pb-1 pr-3 pl-3 mt-3 corpo_impressao']/div[4]/div[2]/div[2]/div[1]/input[1]

# Nome do cliente
XPATH_NOME_CLIENTE=//div[4]//div[1]//div[1]//div[1]//input[1]

# Menu Produção (usado para ir para Resultados)
XPATH_MENU_PRODUCAO=//li[@class='nav-item dropdown show']//a[@id='dropdown05']

# Sub-menu Resultados
XPATH_SUBMENU_RESULTADOS=//a[normalize-space()='Resultados']

# Filtros de ID na tela de Resultados
XPATH_ID_INICIAL=//input[@id='idPedidoInicialFiltro']
XPATH_ID_FINAL=//input[@id='idPedidoFinalFiltro']

# Botão PDF do laudo na primeira linha da seção Solos (tr[1] = 1º resultado)
# O XPath original era tr[3] (linha 3 geral) — ajustado para tr[1] após filtrar por pedido específico
# Se o PDF não for encontrado, tente tr[2] ou tr[3] e ajuste aqui
XPATH_BTN_PDF=//tbody/tr[1]/td[4]/div[1]/div[1]/button[2]

# --- MENSAGEM WHATSAPP ---
# Variáveis disponíveis: {nome}, {numero_pedido}, {data}
MSG_TEMPLATE=Olá, {nome}! 🧪 Seu laudo do pedido nº {numero_pedido} está disponível. Data de liberação: {data}. Em caso de dúvidas, ligue: (62) 4018-4562. Att, Laboratório Solo & Companhia.
